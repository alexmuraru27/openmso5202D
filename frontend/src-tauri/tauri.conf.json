{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openmso5202D",
  "version": "0.1.0",
  "identifier": "com.openmso5202d.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "openmso5202D",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "minWidth": 1000,
        "minHeight": 1000,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png"
    ]
  }
}
