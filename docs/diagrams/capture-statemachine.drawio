<mxfile host="app.diagrams.net" agent="openmso5202D" version="24.7.17">
  <diagram id="capture-state-machine" name="Capture state machine">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2520" pageHeight="2360" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="CAPTURE STATE MACHINE — backend/src/control: CaptureSpec::prepare_plan() and CaptureSpec::capture_plan(), executed op by op by execute()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="320" y="20" width="1560" height="50" as="geometry" /></mxCell>

        <mxCell id="p0" value="(a) PREPARE&#10;capture::prepare(context, spec)&#10;device.clear_link()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=13;" vertex="1" parent="1"><mxGeometry x="260" y="140" width="400" height="70" as="geometry" /></mxCell>
        <mxCell id="p1" value="Op::DefaultSetup   (if spec.reset)&#10;open_menu(Key::DefaultSetup, [25])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="260" y="250" width="400" height="60" as="geometry" /></mxCell>
        <mxCell id="p2" value="Op::SetChannel { channel, on }&#10;set_channel(): poll device.channel_has_data(ch-1)&#10;press Key::Ch1Menu / Ch2Menu, CHANNEL_ATTEMPTS = 5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="350" width="400" height="90" as="geometry" /></mxCell>
        <mxCell id="p3" value="Op::SetProbe { channel, probe }&#10;cycle_until(Fn4, ring 4, VERT-CHn-PROBE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="480" width="400" height="60" as="geometry" /></mxCell>
        <mxCell id="p4" value="Op::SetVoltsPerDiv { channel, millivolts }&#10;converge(Knob::volts_per_div(ch), tolerance 0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="580" width="400" height="60" as="geometry" /></mxCell>
        <mxCell id="p5" value="Op::SetCoupling { channel, coupling }&#10;cycle_until(Fn1, ring 3, VERT-CHn-COUP)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="680" width="400" height="60" as="geometry" /></mxCell>
        <mxCell id="p6" value="Op::SetBandwidthLimit { channel, limited }&#10;cycle_until(Fn2, ring 2, VERT-CHn-20MHZ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="780" width="400" height="60" as="geometry" /></mxCell>
        <mxCell id="p7" value="Op::SetInvert { channel, inverted }&#10;cycle_until(Fn5, ring 2, VERT-CHn-RPHASE)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="880" width="400" height="60" as="geometry" /></mxCell>
        <mxCell id="p8" value="Op::SetTimePerDiv { nanoseconds }   (if timebase_ns)&#10;converge(Knob::TimePerDiv, tolerance 0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="990" width="400" height="64" as="geometry" /></mxCell>
        <mxCell id="p9" value="Op::SetTrigger { setup }   (if spec.trigger)&#10;trigger::apply_reporting() — FIELDS = 6, advance(done, 6)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="1094" width="400" height="64" as="geometry" /></mxCell>
        <mxCell id="p10" value="Op::SetTriggerValue { what, target }  per trigger_values&#10;trigger::read(settings).kind, trigger::set_value()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="1198" width="400" height="64" as="geometry" /></mxCell>
        <mxCell id="p11" value="trigger.is_none_or(kind.has_level())?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="1302" width="400" height="90" as="geometry" /></mxCell>
        <mxCell id="p12" value="Op::SetTriggerLevel { position }&#10;converge_within(Knob::TriggerLevel, TRIGGER_TOLERANCE 0,&#10;TRIGGER_LEVEL_STEPS 220, level_for_convergence)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="1432" width="400" height="86" as="geometry" /></mxCell>
        <mxCell id="p13" value="Op::SetDepth { depth }   (last)&#10;depth_walk(): Key::MenuAcquire → menu 17,&#10;key_edge(Fn5) over DEPTH_RING [0, 4, 6, 7]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="1558" width="400" height="86" as="geometry" /></mxCell>
        <mxCell id="p14" value="prepare complete — scope configured, running" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="1684" width="400" height="50" as="geometry" /></mxCell>

        <mxCell id="b0" value="Every prepare op is closed-loop&#10;(control/converge.rs)&#10;open_menu(): MENU_ATTEMPTS = 4, MENU_POLLS = 6" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="1810" width="400" height="86" as="geometry" /></mxCell>
        <mxCell id="c1" value="press key / turn knob&#10;device.press(key) | device.turn(knob, dir, 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="1996" width="400" height="60" as="geometry" /></mxCell>
        <mxCell id="c2" value="sleep SETTLE = 400 ms&#10;device.read_settings()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="1996" width="400" height="60" as="geometry" /></mxCell>
        <mxCell id="c3" value="read(settings) == target&#10;(or within tolerance)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1260" y="1986" width="400" height="80" as="geometry" /></mxCell>
        <mxCell id="c4" value="next Op" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1780" y="1996" width="240" height="60" as="geometry" /></mxCell>
        <mxCell id="c5" value="Error::Unexpected&#10;converge: &quot;stopped at V before reaching T (end stop or invalid value)&quot;&#10;cycle_until: &quot;walked all N positions without reaching T&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1240" y="2130" width="440" height="90" as="geometry" /></mxCell>

        <mxCell id="g1" value="prepare_plan() walks channel [1, 2] in order:&#10;SetChannel always, then the five vertical ops&#10;only when on = spec.channels.contains(channel)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="350" width="480" height="90" as="geometry" /></mxCell>
        <mxCell id="g2" value="Guard: probe BEFORE volts/div — the probe factor&#10;multiplies what every volts figure means.&#10;Guard: set_volts_per_div errors &quot;CHn is off, so its&#10;volts/div knob is inert&quot; unless channel_shown(ch)." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="590" width="480" height="100" as="geometry" /></mxCell>
        <mxCell id="g3" value="ensure_channel_menu(): opens the CH menu only if&#10;menu_id() != 1/2 or CONTROL-DISP-MENU != 1 — the&#10;CH button also toggles the channel, so the display&#10;state is read before and restored after." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="470" width="480" height="100" as="geometry" /></mxCell>
        <mxCell id="g4" value="Guard: the level is skipped when the mode's knob&#10;is inert — TriggerType::has_level() is false for Slope&#10;(converging there fails on a phantom end stop)." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="1302" width="480" height="86" as="geometry" /></mxCell>
        <mxCell id="g5" value="Guard: SetDepth is LAST — the channels must be&#10;settled first (1M is single-channel). set_depth()&#10;retries the walk DEPTH_WALK_ATTEMPTS = 3 times,&#10;resyncing the transport before each retry." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="1558" width="480" height="100" as="geometry" /></mxCell>

        <mxCell id="q0" value="(b) CAPTURE&#10;capture::capture(context, spec)&#10;device.clear_link()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1360" y="140" width="470" height="70" as="geometry" /></mxCell>
        <mxCell id="q1" value="Op::ArmSingle&#10;arm_single(): resume_run(true) if is_stopped(),&#10;then press Key::Single once (no armed-state check)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="250" width="470" height="86" as="geometry" /></mxCell>
        <mxCell id="q2" value="Op::WaitCaptured { timeout_s = wait_trig_s }&#10;wait_captured(): read_settings().trig_state()&#10;every 200 ms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="376" width="470" height="86" as="geometry" /></mxCell>
        <mxCell id="q3" value="trig_state().is_stopped()?&#10;TrigState in { Stop 0, SingleCaptured 5 }" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="502" width="470" height="100" as="geometry" /></mxCell>
        <mxCell id="q6" value="LOOP HEAD — save_csv() entry, run for EVERY source&#10;1. guard first: read_settings(); if not is_stopped() → force&#10;2. open_csv_menu(): idempotent, menu_id() == 48 → return,&#10;else open_menu(Key::MenuSaveRecall, [47, 48]) then Fn3 → 48" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="642" width="470" height="110" as="geometry" /></mxCell>
        <mxCell id="q7" value="for source in spec.sources()  (CsvSource::Ch1, Ch2)&#10;Op::SaveCsv { source } → select_source():&#10;csv::selected_source(device.screenshot()) == source?&#10;else press Fn1, SOURCE_SETTLE 1 s, SOURCE_ATTEMPTS 6&#10;then list_wavedata() for the &quot;before&quot; baseline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="792" width="470" height="130" as="geometry" /></mxCell>
        <mxCell id="q8" value="press SAVE_SOFTKEY (Fn2) ONCE&#10;twice the first time (SAVE_PRESS_GAP 800 ms) while&#10;session.filelist_open is false" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="962" width="470" height="86" as="geometry" /></mxCell>
        <mxCell id="q9" value="await_new_file(before, save_timeout(depth), expected)&#10;poll list_wavedata_if_reachable() for a new WaveData*.csv,&#10;then size stable over 3 equal readings (700 ms apart)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1360" y="1088" width="470" height="86" as="geometry" /></mxCell>
        <mxCell id="q10" value="await_save_finished()&#10;poll csv::save_in_progress(device.screenshot())&#10;every 1500 ms until BANNER_TIMEOUT = 120 s" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="1214" width="470" height="86" as="geometry" /></mxCell>
        <mxCell id="q11" value="another source left to save?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="1340" width="470" height="80" as="geometry" /></mxCell>
        <mxCell id="q12" value="deferred read-back: Op::Download { source } per source&#10;download(): device.download_with(file.path(), advance)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="1460" width="470" height="70" as="geometry" /></mxCell>
        <mxCell id="q13" value="spec.delete_after?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="1570" width="470" height="80" as="geometry" /></mxCell>
        <mxCell id="q14" value="Op::ClearCard&#10;clear_card(): press DELETE_SOFTKEY (Fn4) remaining&#10;(+1 if list closed) times, CLEAR_ROUNDS = 4 passes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="1690" width="470" height="86" as="geometry" /></mxCell>
        <mxCell id="q15" value="finalize_capture(device) — runs after ANY abort as well as&#10;on success: capture() calls it after execute() regardless&#10;resync → resume_run(true) → press Fn6 (Back) → resync" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1360" y="1816" width="470" height="100" as="geometry" /></mxCell>

        <mxCell id="d0" value="execute(context, plan)&#10;is_cancelled() checked at each step boundary → Error::Cancelled.&#10;Emits StepState::Started → Completed { elapsed_ms },&#10;or Failed { error } and returns — stops at the first failure." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="140" width="480" height="120" as="geometry" /></mxCell>
        <mxCell id="d1" value="elapsed &gt; FORCE_AFTER = 4 s and not forced yet&#10;press Key::ForceTrigger ONCE, keep polling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1890" y="490" width="440" height="76" as="geometry" /></mxCell>
        <mxCell id="d2" value="ABORT: Error::Unexpected&#10;&quot;no trigger within {timeout}, even after forcing —&#10;is the signal present?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1890" y="610" width="440" height="90" as="geometry" /></mxCell>
        <mxCell id="d3" value="save_csv() guard: if not is_stopped(), press&#10;Key::ForceTrigger up to 3×; still running →&#10;&quot;scope is {state}, not holding a captured record&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1890" y="730" width="440" height="90" as="geometry" /></mxCell>
        <mxCell id="d4" value="await_new_file: re-press Fn2 only after&#10;SAVE_RETRY_GRACE = 45 s — pressing during the&#10;write corrupts the save and advances the Source radio" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1890" y="1088" width="440" height="90" as="geometry" /></mxCell>
        <mxCell id="d5" value="ABORT: &quot;no CSV appeared on the card within&#10;{timeout} — is a card inserted and mounted?&quot;&#10;or &quot;{name} never stopped growing within {timeout}&quot;&#10;or &quot;the scope stayed busy after the save&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1890" y="1214" width="440" height="110" as="geometry" /></mxCell>
        <mxCell id="d6" value="ABORT: &quot;downloaded N bytes but the card&#10;reports E — truncated&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1890" y="1460" width="440" height="76" as="geometry" /></mxCell>
        <mxCell id="d7" value="ABORT: &quot;{left} exported CSV(s) still on the card&#10;after 4 passes&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1890" y="1690" width="440" height="76" as="geometry" /></mxCell>
        <mxCell id="d8" value="capture() is re-pressable: no reset, no reconfigure.&#10;capture_plan() = ArmSingle, WaitCaptured, SaveCsv per&#10;source, then Download per source, then ClearCard." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1890" y="140" width="440" height="90" as="geometry" /></mxCell>

        <mxCell id="ep01" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p0" target="p1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ep12" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p1" target="p2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ep23" value="if on" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p2" target="p3"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-24.5" /></mxGeometry></mxCell>
        <mxCell id="ep28" value="if off — vertical ops skipped" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;dashed=1;labelBackgroundColor=#0e1116;exitX=0;exitY=0.25;entryX=0;entryY=0.2;" edge="1" parent="1" source="p2" target="p8"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="140" y="395" /><mxPoint x="140" y="1022" /></Array><mxPoint as="offset" x="-5" y="171" /></mxGeometry></mxCell>
        <mxCell id="ep34" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p3" target="p4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ep45" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p4" target="p5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ep56" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p5" target="p6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ep67" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="p6" target="p7"><mxGeometry relative="1" as="geometry" /></mxCell>
