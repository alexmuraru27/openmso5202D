<mxfile host="app.diagrams.net" agent="openmso5202D" version="24.7.17">
  <diagram id="trigger-menu-navigation" name="Trigger menus">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2460" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="TRIGGER MENU NAVIGATION — backend/src/control/trigger.rs&#10;pages by CONTROL-MENUID, moves by softkey (Key::Fn1..Fn6)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=15;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="2340" height="60" as="geometry" /></mxCell>

        <mxCell id="noteBar" value="The menu bar must be VISIBLE.&#10;CONTROL-MENUID keeps its value when Fn0 hides the bar, so open_trigger() also checks CONTROL-DISP-MENU == 1: softkeys sent to a hidden bar do nothing at all, which looks exactly like a run of dropped presses.&#10;Menu 25 (Default Setup) is not a trigger page." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingRight=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="60" y="130" width="560" height="130" as="geometry" /></mxCell>

        <mxCell id="entry" value="open_trigger()&#10;press Key::MenuTrigger (42), ATTEMPTS = 6&#10;accept only when CONTROL-DISP-MENU == 1&#10;AND menu_id() in FIRST_PAGES = [5, 6, 8, 11, 22, 24, 38]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="680" y="140" width="640" height="90" as="geometry" /></mxCell>

        <mxCell id="goto" value="goto_type(kind)&#10;converge::cycle_until(Fn1, TYPE_RING = 6, &quot;TRIG-TYPE&quot;, code)&#10;then RENORMALISE = 3: press MenuTrigger until menu_id() in kind.menus()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="680" y="320" width="640" height="80" as="geometry" /></mxCell>

        <mxCell id="noteNav" value="The trigger key CANNOT navigate.&#10;Key::MenuTrigger (42) always reopens the page of the CURRENT TRIG-TYPE, so it only gets you INTO the tree.&#10;Between types you navigate by cycling Fn1 (KEY_TYPE) until TRIG-TYPE reads the target code — goto_type().&#10;Fn1 only selects the type on a FIRST page; on page 2 the same key means something else." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingRight=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="1400" y="130" width="700" height="140" as="geometry" /></mxCell>

        <mxCell id="pEdge" value="Edge — TRIG-TYPE 0&#10;menus() = [5, 11]&#10;source_ring 5&#10;has_level true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="560" width="240" height="90" as="geometry" /></mxCell>
        <mxCell id="pVideo" value="Video — TRIG-TYPE 1&#10;menus() = [8]&#10;source_ring 4&#10;has_level true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="370" y="560" width="240" height="90" as="geometry" /></mxCell>
        <mxCell id="pPulse" value="Pulse — TRIG-TYPE 2&#10;menus() = [6]&#10;source_ring 4&#10;has_level true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="680" y="560" width="240" height="90" as="geometry" /></mxCell>
        <mxCell id="pSlope" value="Slope — TRIG-TYPE 3&#10;menus() = [22]&#10;source_ring 4&#10;has_level FALSE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="990" y="560" width="240" height="90" as="geometry" /></mxCell>
        <mxCell id="pOver" value="Overtime — TRIG-TYPE 4&#10;menus() = [38]&#10;source_ring 2&#10;has_level true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1300" y="560" width="240" height="90" as="geometry" /></mxCell>
        <mxCell id="pAlter" value="Alter — TRIG-TYPE 5&#10;menus() = [24] ALTER_MENU&#10;source_ring 2 (unused — apply() branches to the channel pages before the source cycle)&#10;per-channel pages below" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1610" y="560" width="476" height="120" as="geometry" /></mxCell>

        <mxCell id="pPulse2" value="Pulse page 2 — menu 7&#10;Fn4 TRIG-PULSE-WHEN&#10;Fn5 knob TRIG-PULSE-TIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="680" y="830" width="240" height="80" as="geometry" /></mxCell>
        <mxCell id="pSlope2" value="Slope page 2 — menu 23&#10;Fn4 TRIG-SLOPE-WHEN&#10;Fn3 knob TRIG-SLOPE-V1 / -V2&#10;Fn5 knob TRIG-SLOPE-TIME" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="990" y="830" width="240" height="90" as="geometry" /></mxCell>
        <mxCell id="pOver2" value="Overtime page 2 — menu 39&#10;Fn5 TRIG-COUP (only box)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1300" y="830" width="240" height="80" as="geometry" /></mxCell>

        <mxCell id="aCh1" value="Alter CH1 pages&#10;Edge 26 · Pulse 27&#10;Video 28 · Overtime 29&#10;Fn1 TRIG-SWAP-CH1-TYPE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="1560" y="850" width="240" height="90" as="geometry" /></mxCell>
        <mxCell id="aCh2" value="Alter CH2 pages&#10;Edge 30 · Pulse 31&#10;Video 32 · Overtime 33&#10;Fn1 TRIG-SWAP-CH2-TYPE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="2160" y="850" width="240" height="90" as="geometry" /></mxCell>

        <mxCell id="fnTable" value="Page 1 softkey map — which field each Fn key owns&#10;&#10;Fn0   hide / show the menu bar (CONTROL-DISP-MENU); never a field&#10;Fn1   KEY_TYPE — TRIG-TYPE, ring TYPE_RING = 6&#10;Fn2   KEY_SOURCE — TRIG-SRC, ring = source_ring()  |  on the Alter base: KEY_ALTER_CH1&#10;Fn3   KEY_POLARITY — ring 2  |  on the Alter base: KEY_ALTER_CH2&#10;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Edge TRIG-EDGE-SLOPE · Video TRIG-VIDEO-NEG · Pulse TRIG-PULSE-NEG&#10;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Slope TRIG-SLOPE-SET · Overtime TRIG-OVERTIME-NEG&#10;Fn4   KEY_MODE — TRIG-MODE, ring 2  |  Video: TRIG-VIDEO-PAL, ring 2&#10;Fn5   KEY_COUPLING — TRIG-COUP, ring 5  |  Video: TRIG-VIDEO-SYN, ring 5&#10;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;Overtime: slot 5 is its TIME (knob-only); TRIG-COUP moves to page 2&#10;Fn6   KEY_PAGE — page turn  |  on an Alter channel page: KEY_ALTER_BACK&#10;Page 2 only: Fn4 = KEY_QUALIFIER (TRIG-PULSE-WHEN / TRIG-SLOPE-WHEN, ring 4)&#10;Alter channel page: Fn1 sub-type (ring 4) · Fn2 polarity · Fn3/Fn4/Fn5 per sub-type" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingRight=10;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="60" y="686" width="610" height="300" as="geometry" /></mxCell>

        <mxCell id="noteLine" value="solid = key press that descends  ·  dashed = return to the previous page" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" vertex="1" parent="1"><mxGeometry x="60" y="1000" width="620" height="46" as="geometry" /></mxCell>

        <mxCell id="noteFn7" value="Fn7 — NEVER PRESS&#10;It opens the logic-analyzer menu (61). trigger.rs presses Fn1–Fn6 only (Fn0 is read about, never pressed); no code path emits Fn7." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f85149;fontColor=#f85149;fontSize=12;align=left;verticalAlign=middle;spacingLeft=10;spacingRight=10;" vertex="1" parent="1"><mxGeometry x="710" y="1000" width="1690" height="46" as="geometry" /></mxCell>

        <mxCell id="noteKnob" value="Knob-only parameters (Adjustable — no keyed entry, Knob::Multipurpose)&#10;PulseWidth TRIG-PULSE-TIME — Pulse page 2, key Fn5&#10;SlopeV1 / SlopeV2 TRIG-SLOPE-V1 / -V2 — Slope page 2, Fn3, TRIG-SLOPE-WIN 0 / 1&#10;SlopeTime TRIG-SLOPE-TIME — Slope page 2, Fn5&#10;OvertimeTime TRIG-OVERTIME-TIME — Overtime page 1, Fn5&#10;VideoLine TRIG-VIDEO-LINE — key() None; press sync_key Fn5 VIDEO_SYNC_RING = 5 times&#10;AlterChx: PulseWidth Fn4 · OvertimeTime Fn3 · VideoLine sync_key Fn4&#10;Level: Knob::TriggerLevel → TRIG-VPOS; inert in Slope (has_level() false)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingRight=14;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="60" y="1070" width="2340" height="158" as="geometry" /></mxCell>

        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="entry" target="goto"><mxGeometry relative="1" as="geometry" /></mxCell>

