        <mxCell id="e8" value="Fn6 KEY_PAGE&#10;open_second_page()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.3;exitY=1;entryX=0.3;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="pPulse" target="pPulse2"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-38" /></mxGeometry></mxCell>
