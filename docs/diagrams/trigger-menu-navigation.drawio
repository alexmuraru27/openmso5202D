        <mxCell id="e11" value="open_trigger()" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;dashed=1;labelBackgroundColor=#0e1116;exitX=0.7;exitY=0;entryX=0.7;entryY=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="pPulse2" target="pPulse"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="42" /></mxGeometry></mxCell>
