<mxfile host="app.diagrams.net" agent="openmso5202D" version="24.7.17">
  <diagram id="uart-decode-algorithm" name="UART decode">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1930" pageHeight="3520" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="UART DECODE ALGORITHM — backend/src/decoder/uart.rs : decode() / decode_once()&#10;bit grid from common.rs (refine_period → sample_grid → sample_cell), framing by FrameLayout::match_frame" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#4bc0e0;fontSize=15;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="900" height="80" as="geometry" /></mxCell>

        <mxCell id="n1" value="uart::decode(trace: &amp;[bool], options: UartOptions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="160" width="460" height="50" as="geometry" /></mxCell>

        <mxCell id="d1" value="options.idle == Idle::Auto ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="310" width="460" height="70" as="geometry" /></mxCell>

        <mxCell id="n2" value="decode_auto_polarity(trace, options)&#10;re-enter decode() with Idle::High and Idle::Low&#10;shorter &gt;= 0.8 * longer → tie broken by&#10;front::idle_level(trace); else the longer wins" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="480" width="460" height="120" as="geometry" /></mxCell>

        <mxCell id="d2" value="options.both_ways ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="700" width="460" height="70" as="geometry" /></mxCell>

        <mxCell id="n3" value="front::both_ways(&#10;|reverse| decode_once(trace, reverse, options),&#10;|frames| frames.len())" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="870" width="460" height="90" as="geometry" /></mxCell>

        <mxCell id="n4" value="decode_once(trace, reverse, options)&#10;if reverse: work on the reversed copy of trace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="1060" width="460" height="60" as="geometry" /></mxCell>

        <mxCell id="n5" value="initial samples-per-bit&#10;baud &gt; 0 and sample_interval_ns &gt; 0 →&#10;initial_spb = (1e9 / baud) / interval&#10;else initial_spb = front::min_pulse(trace) as f64" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="1220" width="460" height="90" as="geometry" /></mxCell>

        <mxCell id="n6" value="bit grid&#10;edge_indices = front::edges(trace)&#10;if edge_indices.len() &gt;= 3:&#10;(spb, phase) = front::refine_period(&#10;edge_indices, initial_spb)&#10;else (initial_spb, first edge or 0.0)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="1410" width="460" height="130" as="geometry" /></mxCell>

        <mxCell id="guard" value="return Vec::new()&#10;(no events)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=13;" vertex="1" parent="1"><mxGeometry x="880" y="2000" width="290" height="60" as="geometry" /></mxCell>

        <mxCell id="n7" value="parity_bits = (parity != Parity::None) as usize&#10;frame_len = 1 + bits + parity_bits + stops" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="1640" width="460" height="70" as="geometry" /></mxCell>

        <mxCell id="n8" value="(bits, centres) =&#10;front::sample_grid(trace, spb, phase, vote = true)&#10;one cell per grid index; majority-voted when spb &gt;= 4.0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="1810" width="460" height="90" as="geometry" /></mxCell>

        <mxCell id="n9" value="idle = (options.idle == Idle::High)&#10;layout = FrameLayout::new(reverse, bits,&#10;parity_bits, stops, frame_len)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="2000" width="460" height="90" as="geometry" /></mxCell>

        <mxCell id="n10" value="candidates = bits.len().saturating_sub(frame_len - 1)&#10;for i in 0..candidates:&#10;matches[i] = layout.match_frame(&#10;&amp;bits[i..i + frame_len], idle, options)&#10;→ Option&lt;(u8, bool)&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="2190" width="460" height="120" as="geometry" /></mxCell>

        <mxCell id="n11" value="(A) fixed-offset tiling&#10;for offset in 0..frame_len: take matches at&#10;offset, offset + frame_len, ...&#10;keep the longest event list (best_tiled);&#10;strictly longer, so the lowest offset wins ties" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="2410" width="460" height="110" as="geometry" /></mxCell>

        <mxCell id="n12" value="(B) greedy resync walk&#10;i = 0; Some(m) → push event, i += frame_len&#10;None → i += 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="590" y="2410" width="380" height="110" as="geometry" /></mxCell>

        <mxCell id="n13" value="frames = if best_tiled.len() &gt;= walked.len()&#10;{ best_tiled } else { walked }&#10;(tiling wins ties)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="2620" width="460" height="100" as="geometry" /></mxCell>

        <mxCell id="n14" value="if reverse { frames.reverse() }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="2820" width="460" height="50" as="geometry" /></mxCell>

        <mxCell id="n15" value="Vec&lt;Event&gt;  (kind: Kind::Byte, value, ok)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=13;" vertex="1" parent="1"><mxGeometry x="285" y="2970" width="460" height="50" as="geometry" /></mxCell>

        <mxCell id="note_auto" value="Idle::Auto is best effort — the docs say to&#10;state the polarity explicitly. decode_auto_polarity&#10;recurses into decode() twice, so both_ways still&#10;applies inside each polarity." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1180" y="480" width="388.65" height="85" as="geometry" /></mxCell>

        <mxCell id="note_bw" value="both_ways retry — common.rs::both_ways + uart.rs decode_once:&#10;forward = decode(false); reverse = decode(true);&#10;returns reverse iff score(&amp;reverse) &gt; score(&amp;forward),&#10;score = |frames| frames.len(); ties keep forward.&#10;The reversed run uses the reversed FrameLayout&#10;[stop*][parity?][data MSB..LSB][start], remaps each&#10;event to (n-1-b, n-1-a) and reverses the frame list." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1180" y="870" width="460.15" height="138" as="geometry" /></mxCell>

        <mxCell id="note_valid" value="match_frame() validation:&#10;reject if cells[start_cell] == idle&#10;reject if any stop cell != idle&#10;value bit b set iff cells[data_cells[b]] == idle&#10;Even: (count_ones + (parity cell == idle)) % 2 == 0&#10;Odd:  same sum % 2 == 1&#10;a parity failure still emits an event with ok = false" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1180" y="2190" width="402.95" height="138" as="geometry" /></mxCell>

        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n1" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d1" target="n2"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>
        <mxCell id="e3" value="no" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0;exitY=0.5;entryX=0;entryY=0.5;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d1" target="d2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="190" y="345" /><mxPoint x="190" y="735" /></Array><mxPoint as="offset" x="0" y="-140" /></mxGeometry></mxCell>
        <mxCell id="e4" value="each polarity" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n2" target="d2"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>
        <mxCell id="e5" value="yes" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d2" target="n3"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>
        <mxCell id="e6" value="no (reverse = false)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0.9;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d2" target="n4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="880" y="735" /><mxPoint x="880" y="1030" /><mxPoint x="699" y="1030" /></Array><mxPoint as="offset" x="0" y="-130" /></mxGeometry></mxCell>
        <mxCell id="e7" value="runs decode_once twice&#10;(reverse = false, then true)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>
        <mxCell id="e8" value="n &lt; 2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f85149;fontColor=#f85149;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0.1;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n4" target="guard"><mxGeometry x="-0.898" relative="1" as="geometry"><Array as="points"><mxPoint x="909" y="1090" /></Array><mxPoint as="offset" x="0" y="-12" /></mxGeometry></mxCell>
        <mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e10" value="initial_spb &lt; 2.0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f85149;fontColor=#f85149;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0.4;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n5" target="guard"><mxGeometry x="-0.888" relative="1" as="geometry"><Array as="points"><mxPoint x="996" y="1265" /></Array><mxPoint as="offset" x="0" y="-12" /></mxGeometry></mxCell>
        <mxCell id="e11" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n5" target="n6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" value="spb &lt; 2.0" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f85149;fontColor=#f85149;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0.65;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n6" target="guard"><mxGeometry x="-0.87" relative="1" as="geometry"><Array as="points"><mxPoint x="1068" y="1475" /></Array><mxPoint as="offset" x="0" y="-12" /></mxGeometry></mxCell>
        <mxCell id="e13" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n6" target="n7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n7" target="n8"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" value="bits.len() &lt; frame_len" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f85149;fontColor=#f85149;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0.9;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n8" target="guard"><mxGeometry x="-0.778" relative="1" as="geometry"><Array as="points"><mxPoint x="1141" y="1855" /></Array><mxPoint as="offset" x="0" y="-12" /></mxGeometry></mxCell>
        <mxCell id="e16" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n8" target="n9"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e17" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n9" target="n10"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e18" value="(A)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.15;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n10" target="n11"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-12" /></mxGeometry></mxCell>
        <mxCell id="e19" value="(B)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.85;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n10" target="n12"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-12" /></mxGeometry></mxCell>
