        <mxCell id="tt" value="TIMING ILLUSTRATION — one frame on the bit grid (bits = 8, parity, stops = 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#4bc0e0;fontSize=14;" vertex="1" parent="1"><mxGeometry x="60" y="3120" width="900" height="40" as="geometry" /></mxCell>

        <mxCell id="tbr" value="frame_len = 1 + bits + parity_bits + stops = 11 cells    —    forward layout [start][data LSB..MSB][parity?][stop*]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="3200" width="1810" height="40" as="geometry" /></mxCell>

        <mxCell id="tc0" value="IDLE / mark&#10;level = idle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc1" value="START  cell 0&#10;!= idle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="200" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc2" value="D0 (LSB)&#10;cell 1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="340" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc3" value="D1&#10;cell 2" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="480" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc4" value="D2&#10;cell 3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="620" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc5" value="D3&#10;cell 4" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc6" value="D4&#10;cell 5" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="900" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc7" value="D5&#10;cell 6" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1040" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc8" value="D6&#10;cell 7" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1180" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc9" value="D7 (MSB)&#10;cell 8" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1320" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc10" value="PARITY&#10;cell 9" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1460" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc11" value="STOP  cell 10&#10;== idle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1600" y="3280" width="130" height="60" as="geometry" /></mxCell>
        <mxCell id="tc12" value="IDLE&#10;next frame" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1740" y="3280" width="130" height="60" as="geometry" /></mxCell>

        <mxCell id="tm1" value="sample_cell centre&#10;phase + (k + 0.5) * spb" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="185" y="3380" width="150" height="70" as="geometry" /></mxCell>
        <mxCell id="tm2" value="bit 0 set iff&#10;cells[1] == idle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="340" y="3380" width="130" height="70" as="geometry" /></mxCell>
        <mxCell id="tm3" value="bit 7 set iff&#10;cells[8] == idle" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1320" y="3380" width="130" height="70" as="geometry" /></mxCell>
        <mxCell id="tm4" value="parity vs&#10;value.count_ones()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1460" y="3380" width="130" height="70" as="geometry" /></mxCell>
        <mxCell id="tm5" value="!= idle rejects&#10;the whole frame" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1600" y="3380" width="130" height="70" as="geometry" /></mxCell>

        <mxCell id="note_grid" value="sample_grid(trace, spb, phase, vote)&#10;phase re-centred into (-spb/2, spb/2]&#10;k0 = floor((0.0 - phase) / spb)&#10;k1 = ((n - 1) - phase) / spb, truncated&#10;one cell per k in k0..k1 → (bits, centres)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1180" y="1810" width="560" height="95" as="geometry" /></mxCell>

        <mxCell id="note_cell" value="sample_cell(trace, centre, spb, vote = true)&#10;index = round_half_even(centre).clamp(0, n - 1)&#10;if !vote || spb &lt; 4.0 → trace[index] as-is&#10;else half = ((spb * 0.25) as usize).max(1) and the cell&#10;is the majority over -half..=half: high * 2 &gt;= total" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1180" y="1913" width="560" height="95" as="geometry" /></mxCell>

        <mxCell id="note_period" value="refine_period(edge_indices, initial_spb)&#10;hierarchical direct search on grid_concentration&#10;(FIRST_SPAN = 128, REACH = 0.02, DRIFT_PER_STEP = 0.25)&#10;then fit_grid() polish, kept only if |refined − spb| ≤ tolerance&#10;else (searched spb, edge_indices[0]); initial estimate only&#10;returned when edges &lt; 3 or initial_spb &lt; 1.0" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1180" y="1410" width="560" height="120" as="geometry" /></mxCell>

        <mxCell id="note_event" value="FrameLayout::event(i, (value, ok), centres, n, reverse)&#10;a = centres[i], b = centres[i + frame_len - 1]&#10;if reverse → (n - 1 - b, n - 1 - a)&#10;Event { start: a.min(b), end: a.max(b), value: Some(value),&#10;ok, kind: Kind::Byte }" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1180" y="2410" width="560" height="100" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
