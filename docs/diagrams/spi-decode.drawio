        <mxCell id="n0" value="SPI DECODE ALGORITHM — backend/src/decoder/spi.rs :: decode()" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0e1116;strokeColor=#4bc0e0;fontColor=#4bc0e0;fontSize=16;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="700" height="50" as="geometry" /></mxCell>
        <mxCell id="n1" value="spi::decode(clock, data,&#10;chip_select, clock_analog,&#10;options: SpiOptions) -&gt; Vec&lt;Event&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=13;" vertex="1" parent="1"><mxGeometry x="440" y="100" width="320" height="70" as="geometry" /></mxCell>
        <mxCell id="n2" value="options.auto_mode?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="430" y="230" width="340" height="100" as="geometry" /></mxCell>
        <mxCell id="n3" value="detect_sample_rising(&#10;clock, data)&#10;data edges cluster on&#10;the shift edge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="820" y="380" width="320" height="100" as="geometry" /></mxCell>
        <mxCell id="n4" value="sample_rising =&#10;options.cpol == options.cpha&#10;(modes 0/3 rising, 1/2 falling)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="390" width="320" height="80" as="geometry" /></mxCell>
        <mxCell id="n5" value="clock_edges = i in 1..n&#10;matching sample_rising" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="440" y="560" width="320" height="60" as="geometry" /></mxCell>
        <mxCell id="n6" value="median_period = median gap&#10;(chip_select.is_none() &amp;&amp;&#10;clock_edges.len() &gt; 2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="440" y="670" width="320" height="80" as="geometry" /></mxCell>
        <mxCell id="n7" value="chip_select supplied?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="430" y="820" width="340" height="100" as="geometry" /></mxCell>
        <mxCell id="n8" value="cs[edge] active?&#10;(active = !cs[edge])" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="40" y="970" width="360" height="130" as="geometry" /></mxCell>
        <mxCell id="n9" value="periods = round_half_even(&#10;gap / median_period)&#10;in 2..=max_missed &amp;&amp;&#10;|gap − periods×median| ≤ 0.5×median?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="790" y="950" width="380" height="170" as="geometry" /></mxCell>
        <mxCell id="n10" value="clock_analog given &amp;&amp;&#10;!gap_has_pulse(...)?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="790" y="1200" width="380" height="130" as="geometry" /></mxCell>
        <mxCell id="note1" value="max_missed = 8 (default)&#10;a gap of 2..=max_missed&#10;periods = missed edges,&#10;rebuilt at k × median_period" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1230" y="960" width="300" height="100" as="geometry" /></mxCell>
        <mxCell id="n11" value="close burst&#10;(real inter-word idle)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="830" y="1390" width="300" height="60" as="geometry" /></mxCell>
        <mxCell id="n12" value="push_bit() for k in 1..periods&#10;(synthesised missed edges)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1230" y="1390" width="300" height="60" as="geometry" /></mxCell>
        <mxCell id="n13" value="gap &gt; word_gap × median&#10;→ close burst (word gap)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="440" y="1200" width="320" height="70" as="geometry" /></mxCell>
        <mxCell id="note2" value="word_gap = 10.0 (default)&#10;idle gap &gt; word_gap ×&#10;median_period splits bursts" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="1340" width="300" height="90" as="geometry" /></mxCell>
        <mxCell id="n14" value="push_bit(bursts, data, edge)&#10;sample data at clock edge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="440" y="1520" width="320" height="60" as="geometry" /></mxCell>
