        <mxCell id="nprepping" value="Preparing&#10;busy = prepare&#10;prepare(config, trigger)&#10;onProgress(prepare:progress)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="700" y="600" width="280" height="90" as="geometry" /></mxCell>
        <mxCell id="nprepared" value="Prepared&#10;prepared = true" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="700" y="770" width="280" height="60" as="geometry" /></mxCell>
