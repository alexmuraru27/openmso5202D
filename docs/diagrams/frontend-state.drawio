        <mxCell id="t1" value="FRONTEND STATE MODEL — App.tsx (status / prepared / busy / result) over api.ts commands" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=15;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1440" height="50" as="geometry" /></mxCell>

        <mxCell id="nbusy" value="BUSY LOCK (single slot)&#10;busy: null | connect | prepare | capture | card&#10;set by doConnect / doPrepare / doCapture, cleared in finally&#10;FilesDialog card jobs: setCardBusy(on) =&gt; busy = card&#10;Connect btn: disabled={busy === connect}&#10;① Prepare: disabled={!connected || busy !== null}&#10;② Arm capture: disabled={!connected || !prepared || busy !== null}&#10;TopProgress phase: Connecting / Preparing / Capturing / Working on card" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=13;" vertex="1" parent="1"><mxGeometry x="40" y="120" width="500" height="220" as="geometry" /></mxCell>

