        <mxCell id="ninval" value="INVALIDATES PREPARE — setPrepared(false)&#10;updateConfig(patch) with any key outside&#10;[protocol, clockChannel, dataChannel]:&#10;channels, channelsSetup, maxFreqHz,&#10;samplesPerCycle, depth&#10;updateTrigger(next) — always&#10;resetSettings() — DEFAULT_CONFIG / DEFAULT_TRIGGER" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="40" y="830" width="440" height="220" as="geometry" /></mxCell>
