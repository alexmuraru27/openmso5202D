<mxfile host="app.diagrams.net" agent="openmso5202D" version="24.7.17">
  <diagram id="usb-transaction-sequence" name="USB transaction">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1880" pageHeight="2620" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t1" value="USB TRANSACTION SEQUENCE — Transport::transact() (backend/src/usb/transport.rs)&#10;reader thread posts the bulk IN read BEFORE the OUT frame is written, or the device stays silent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#e6edf3;fontSize=15;" vertex="1" parent="1"><mxGeometry x="180" y="20" width="1220" height="60" as="geometry" /></mxCell>

        <mxCell id="L1" value="Host thread" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0e1116;strokeColor=#2b3444;fontColor=#4bc0e0;fontSize=14;dashed=1;" vertex="1" parent="1"><mxGeometry x="180" y="110" width="360" height="44" as="geometry" /></mxCell>
        <mxCell id="L2" value="Reader thread" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0e1116;strokeColor=#2b3444;fontColor=#4bc0e0;fontSize=14;dashed=1;" vertex="1" parent="1"><mxGeometry x="640" y="110" width="360" height="44" as="geometry" /></mxCell>
        <mxCell id="L3" value="Scope (049f:505a)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0e1116;strokeColor=#f5c542;fontColor=#f5c542;fontSize=14;dashed=1;" vertex="1" parent="1"><mxGeometry x="1060" y="110" width="340" height="44" as="geometry" /></mxCell>

        <mxCell id="n1" value="transact(payload)&#10;→ transact_with(payload,&#10;DEFAULT_TIMEOUT = 3000 ms,&#10;DEFAULT_RETRIES = 2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="190" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="n2" value="transact_validated(leader, payload, timeout, retries)&#10;for attempt in 0..=retries" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="130" y="320" width="460" height="90" as="geometry" /></mxCell>

        <mxCell id="n3" value="transact_once(leader, payload, timeout)&#10;mpsc::channel::&lt;()&gt;() → ready_tx / ready_rx&#10;thread::spawn(reader)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="450" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="r1" value="ready_tx.send(())&#10;&quot;about to post the bulk IN read&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="640" y="450" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="n4" value="ready_rx.recv_timeout(500 ms)&#10;host waits for the ready signal&#10;(failure ignored)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="610" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="r2" value="recv_frame(&amp;handle, &amp;rx, timeout)&#10;locks rx, blocks in&#10;read_bulk(EP_IN = 0x81, READ_CHUNK = 65536)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="640" y="610" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="n5" value="thread::sleep(TRANSACT_POST)&#10;TRANSACT_POST = 15 ms&#10;below ~12 ms the write races the IN URB&#10;and the device goes silent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="750" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="n6" value="protocol::build_with(leader, payload)&#10;log_usb(&quot;OUT&quot;, &amp;frame)&#10;write_bulk(EP_OUT = 0x02, &amp;frame, 2000 ms)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="890" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="s1" value="device replies (IN read already pending)&#10;0x53 | len_LE16 | echo = selector|0x80&#10;| subtype | data… | checksum" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1060" y="890" width="340" height="90" as="geometry" /></mxCell>

        <mxCell id="r3" value="recv_frame fills rx until&#10;frame_total_len(head) bytes present&#10;buf.drain(..total) → one whole frame&#10;(rx persists across transactions)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="640" y="1030" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="n7" value="reader.join()&#10;prefer the received frame even if&#10;write_bulk reported an error" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="1170" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="d1" value="transact_once(...)&#10;.and_then(validate_reply)&#10;— inside the retry loop" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;" vertex="1" parent="1"><mxGeometry x="170" y="1310" width="380" height="120" as="geometry" /></mxCell>

        <mxCell id="n8" value="Ok → transact_with only:&#10;protocol::verify(&amp;frame) (2nd verify)&#10;return payload: echo | subtype | data…&#10;transact_raw returns the raw frame" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="640" y="1500" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="f1" value="Err → last = Some(e); self.resync()&#10;rx.clear() + drain EP_IN&#10;64 iterations × 60 ms&#10;then re-send the same payload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#f85149;fontColor=#f85149;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="1500" width="360" height="90" as="geometry" /></mxCell>

        <mxCell id="note1" value="LEADER-MATCH RULE (validate_reply)&#10;&#10;leader == LEADER_DATA (0x53):&#10;full protocol::verify — leader, declared&#10;length, checksum.&#10;&#10;else (LEADER_CMD = 0x43): only&#10;frame.first() == Some(&amp;leader), else&#10;Error::Framing(&quot;bad leader 0x..&quot;).&#10;&#10;It deliberately does NOT check the&#10;selector|0x80 echo: a 0x13 key press is&#10;not idempotent, so retrying on a&#10;one-behind reply would double-press." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1470" y="1040" width="350" height="330" as="geometry" /></mxCell>

        <mxCell id="note2" value="FRAME &amp; CONSTANTS&#10;&#10;leader | len_LE16 | payload | checksum&#10;len = payload_len + 1 = frame_len − 3&#10;checksum = sum(all preceding) &amp; 0xFF&#10;&#10;LEADER_DATA = 0x53, LEADER_CMD = 0x43&#10;EP_OUT = 0x02, EP_IN = 0x81, INTERFACE = 0&#10;VID = 0x049F, PID = 0x505A&#10;&#10;TRANSACT_POST = 15 ms&#10;DEFAULT_TIMEOUT = 3000 ms&#10;DEFAULT_RETRIES = 2&#10;READ_CHUNK = 65536 B&#10;write_bulk timeout = 2000 ms&#10;ready wait = 500 ms&#10;resync read = 60 ms × 64" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1470" y="190" width="350" height="420" as="geometry" /></mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" value="spawn" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0;entryY=0.5;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n3" target="r1"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-14" /></mxGeometry></mxCell>
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="ready signal" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#4bc0e0;fontColor=#4bc0e0;fontSize=11;labelBackgroundColor=#0e1116;exitX=0;exitY=0.75;entryX=1;entryY=0.5;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="r1" target="n4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="590" y="518" /><mxPoint x="590" y="655" /></Array><mxPoint as="offset" x="0" y="-16" /></mxGeometry></mxCell>
        <mxCell id="e6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="r1" target="r2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n5" target="n6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="OUT frame on EP_OUT" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0;entryY=0.5;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n6" target="s1"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-12" /></mxGeometry></mxCell>
        <mxCell id="e10" value="IN frame on EP_IN (0x81)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=1;entryY=0.5;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="s1" target="r3"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-12" /></mxGeometry></mxCell>
        <mxCell id="e11" value="pending read blocks here" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="r2" target="r3"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="140" /></mxGeometry></mxCell>
        <mxCell id="e12" value="join returns the frame" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="r3" target="n7"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>
        <mxCell id="e13" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n7" target="d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="Ok" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d1" target="n8"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>
        <mxCell id="e15" value="Err (timeout from recv_frame;&#10;framing / bad leader from validate_reply)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f85149;fontColor=#f85149;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d1" target="f1"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>
        <mxCell id="e16" value="next attempt (else Err(last))" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f85149;fontColor=#f85149;fontSize=11;labelBackgroundColor=#0e1116;exitX=0;exitY=0.5;entryX=0;entryY=0.5;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="f1" target="n2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="90" y="1545" /><mxPoint x="90" y="365" /></Array><mxPoint as="offset" x="0" y="-380" /></mxGeometry></mxCell>

        <mxCell id="dv" value="lanes above do not apply — collect_multiframe runs on the calling host thread" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#0e1116;strokeColor=#2b3444;fontColor=#7d8590;fontSize=12;dashed=1;" vertex="1" parent="1"><mxGeometry x="60" y="1650" width="1360" height="34" as="geometry" /></mxCell>

        <mxCell id="t2" value="MULTI-FRAME COLLECTION — Device::collect_multiframe(first, timeout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#e6edf3;fontSize=15;" vertex="1" parent="1"><mxGeometry x="180" y="1720" width="800" height="50" as="geometry" /></mxCell>

        <mxCell id="m1" value="first frame from transact_with(...)&#10;MAX_FRAMES = 2000&#10;DATA_OFFSET = 2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="1840" width="320" height="80" as="geometry" /></mxCell>

        <mxCell id="d2" value="match frame.get(1)&#10;subtype byte" style="rhombus;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="140" y="1990" width="400" height="110" as="geometry" /></mxCell>

        <mxCell id="m2" value="transport.recv(timeout)&#10;→ next frame&#10;Err(_) → break" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="180" y="2330" width="320" height="80" as="geometry" /></mxCell>

        <mxCell id="dt" value="subtype::DATA = 0x01&#10;data.extend_from_slice(&amp;frame[2..])" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="170" y="2180" width="340" height="80" as="geometry" /></mxCell>

        <mxCell id="en" value="subtype::END = 0x02&#10;break — the end marker MUST be consumed&#10;or the stream desyncs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="2180" width="340" height="80" as="geometry" /></mxCell>

        <mxCell id="ret" value="Ok(data)&#10;(partial data on Err / frame-bound exit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=13;" vertex="1" parent="1"><mxGeometry x="760" y="2470" width="340" height="70" as="geometry" /></mxCell>

        <mxCell id="note3" value="DATA OFFSETS PER REPLY TYPE&#10;&#10;File read 0x90 → 2&#10;  echo | subtype | data…&#10;Framebuffer 0xa0 → 2&#10;  no size frame; exactly 768000 B&#10;Acquire 0x82 → 3&#10;  echo | 0x01 | src | samples…&#10;Shell (0x43) → payload_of(), then drop&#10;  a leading 0x91 (strip_shell_frame)&#10;&#10;subtype::NODATA = 0x03 (acquire, nothing&#10;to return).&#10;&#10;download_with() uses its own loop that&#10;stops on ANY non-DATA frame, then calls&#10;transport.resync() to clear the tail." style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1470" y="1840" width="360" height="360" as="geometry" /></mxCell>

        <mxCell id="e20" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="m1" target="d2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e22" value="0x01" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d2" target="dt"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="-20" y="0" /></mxGeometry></mxCell>
        <mxCell id="e23" value="0x02" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.75;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d2" target="en"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="440" y="2140" /><mxPoint x="930" y="2140" /></Array><mxPoint as="offset" x="-160" y="-14" /></mxGeometry></mxCell>
        <mxCell id="e24" value="_ catch-all (SIZE frame 0x00 / stale one-behind frame):&#10;skip — no data taken — and keep reading" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#4bc0e0;fontColor=#4bc0e0;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0.75;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="d2" target="d2"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="640" y="2045" /><mxPoint x="640" y="1960" /><mxPoint x="440" y="1960" /></Array><mxPoint as="offset" x="190" y="-46" /></mxGeometry></mxCell>
        <mxCell id="e26" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="dt" target="m2"><mxGeometry relative="1" as="geometry" /></mxCell>
