<mxfile host="app.diagrams.net" agent="openmso5202D" version="24.7.17">
  <diagram id="i2c-decode-state-machine" name="I2C decode">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1760" pageHeight="2137" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="I²C DECODE STATE MACHINE — backend/src/decoder/i2c.rs :: decode() → decode_forward()&#10;SCL + SDA logic traces → Vec&lt;Event&gt; (Kind::Start / RepeatedStart / Address / Byte / Stop)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=14;" vertex="1" parent="1"><mxGeometry x="60" y="20" width="900" height="60" as="geometry" /></mxCell>

        <mxCell id="n1" value="IDLE&#10;in_frame = false&#10;SCL rising edges ignored (no bits pushed)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="140" width="390" height="80" as="geometry" /></mxCell>

        <mxCell id="n2" value="START&#10;emits Kind::Start (value = None, ok = true)&#10;bits.clear(); byte_start = None" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="430" y="390" width="390" height="80" as="geometry" /></mxCell>

        <mxCell id="n3" value="ADDRESS — accumulate bits&#10;expect_address || expect_address_low&#10;on scl[i] &amp;&amp; !scl[i-1]: bits.push(sda[i])&#10;7 address bits + R/W (LSB of value)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="430" y="600" width="390" height="120" as="geometry" /></mxCell>

        <mxCell id="n4" value="ACK / NACK cell (bits.len() == 9)&#10;ack = !bits[8]  →  Event.ok&#10;emits Kind::Address&#10;value = bits[..8] folded MSB first" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="430" y="867" width="390" height="90" as="geometry" /></mxCell>

        <mxCell id="n5" value="DATA — accumulate bits&#10;expect_address = false&#10;8 data bits sampled on SCL rising, MSB first&#10;value = (acc &lt;&lt; 1) | u8::from(b)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="430" y="1087" width="390" height="90" as="geometry" /></mxCell>

        <mxCell id="n6" value="ACK / NACK cell (bits.len() == 9)&#10;ack = !bits[8]  →  Event.ok&#10;emits Kind::Byte" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=13;" vertex="1" parent="1"><mxGeometry x="430" y="1307" width="390" height="90" as="geometry" /></mxCell>

        <mxCell id="n7" value="REPEATED START&#10;emits Kind::RepeatedStart&#10;(SDA 1→0, SCL high, in_frame)&#10;expect_address = true; bits.clear()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="860" y="140" width="330" height="120" as="geometry" /></mxCell>

        <mxCell id="n8" value="STOP&#10;emits Kind::Stop (value = None, ok = true)&#10;in_frame = false&#10;expect_address_low = false&#10;(expect_address is NOT cleared)&#10;bits.clear(); byte_start = None" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="460" y="1527" width="330" height="140" as="geometry" /></mxCell>

        <mxCell id="c1" value="Bus-condition guard for START / STOP:&#10;both tested only while scl[i] &amp;&amp; scl[i-1]&#10;(SCL high across the sample pair)&#10;The guard is checked on EVERY sample pair, from&#10;any state — edges are shown only from the DATA&#10;phase for clarity (a repeated START or STOP during&#10;the ADDRESS phase is equally legal)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1250" y="140" width="420" height="150" as="geometry" /></mxCell>

        <mxCell id="c2" value="Kind selection at the 9th bit:&#10;expect_address &amp;&amp; (value &amp; 0xF8) == 0xF0&#10;→ Kind::Address; expect_address = false,&#10;expect_address_low = true&#10;else expect_address → Kind::Address; expect_address = false&#10;else expect_address_low → Kind::Address;&#10;expect_address_low = false&#10;else → Kind::Byte" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1250" y="560" width="445.85" height="180" as="geometry" /></mxCell>

        <mxCell id="c3" value="ok flag source:&#10;ok = ack = !bits[8]&#10;9th SCL rising samples SDA; a LOW there is&#10;the receiver's ACK (ok = true), a HIGH is a&#10;NACK (ok = false → Event::text() suffix &quot;!&quot;)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1250" y="780" width="340" height="150" as="geometry" /></mxCell>

        <mxCell id="c4" value="Event span:&#10;start = byte_start.unwrap_or(i)&#10;(first SCL rising of the byte)&#10;end = i (the ACK bit's sample index)&#10;markers use start = end = i" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1250" y="960" width="340" height="130" as="geometry" /></mxCell>

        <mxCell id="c5" value="decode(scl, sda, anchor):&#10;Anchor::Start → forward events&#10;Anchor::Auto &amp;&amp; has_start → forward events&#10;else → decode_end_anchored():&#10;rises before the last pre-STOP falling edge,&#10;leading partial dropped (usable.len() % 9),&#10;9-clock chunks, all Kind::Byte, STOPs kept;&#10;&lt;9 usable rises → forward events unchanged" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1250" y="1140" width="420" height="180" as="geometry" /></mxCell>

        <mxCell id="e1" value="sda[i-1] &amp;&amp; !sda[i] while SCL high&#10;(SDA falls) — in_frame == false" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n1" target="n2"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-24" /></mxGeometry></mxCell>

        <mxCell id="e2" value="in_frame = true; expect_address = true" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n2" target="n3"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="-45" /></mxGeometry></mxCell>

        <mxCell id="e3" value="9th SCL rising edge&#10;bits.len() == 9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n3" target="n4"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>

        <mxCell id="e4" value="bits.clear(); byte_start = None&#10;next SCL rising while in_frame" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n4" target="n5"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>

        <mxCell id="e5" value="10-bit address: (value &amp; 0xF8) == 0xF0&#10;expect_address = false, expect_address_low = true&#10;→ 2nd Kind::Address (low byte)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0;exitY=0.5;entryX=0;entryY=0.5;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n4" target="n3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="360" y="912" /><mxPoint x="360" y="660" /></Array><mxPoint as="offset" x="-60" y="0" /></mxGeometry></mxCell>

        <mxCell id="e6" value="9th SCL rising edge&#10;bits.len() == 9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n5" target="n6"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>

        <mxCell id="e7" value="loop: next byte&#10;bits.clear(); byte_start = None" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0;exitY=0.5;entryX=0;entryY=0.5;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n6" target="n5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="360" y="1352" /><mxPoint x="360" y="1132" /></Array><mxPoint as="offset" x="-60" y="0" /></mxGeometry></mxCell>

        <mxCell id="e8" value="SDA falls while SCL high&#10;in_frame == true" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.3;entryX=0.18;entryY=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n5" target="n7"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="920" y="1114" /></Array><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>

        <mxCell id="e9" value="SDA falls while SCL high&#10;in_frame == true" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.5;entryX=0.667;entryY=1;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n6" target="n7"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1080" y="1352" /></Array><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>

        <mxCell id="e10" value="restart frame: expect_address = true&#10;expect_address_low = false" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.02;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n7" target="n3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="866" y="560" /></Array><mxPoint as="offset" x="-80" y="-24" /></mxGeometry></mxCell>

        <mxCell id="e11" value="!sda[i-1] &amp;&amp; sda[i] while SCL high&#10;(SDA rises)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0.5;exitY=1;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n6" target="n8"><mxGeometry relative="1" as="geometry"><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>

        <mxCell id="e12" value="SDA rises while SCL high (mid-byte STOP)" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=1;exitY=0.7;entryX=1;entryY=0.66;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n5" target="n8"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1000" y="1150" /><mxPoint x="1000" y="1619" /></Array><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>

        <mxCell id="e13" value="in_frame = false → bits ignored again" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;rounded=1;html=1;jettySize=auto;strokeColor=#7d8590;fontColor=#adbac7;fontSize=11;labelBackgroundColor=#0e1116;exitX=0;exitY=0.5;entryX=0.5;entryY=0;exitDx=0;exitDy=0;entryDx=0;entryDy=0;" edge="1" parent="1" source="n8" target="n1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="120" y="1597" /><mxPoint x="120" y="100" /></Array><mxPoint as="offset" x="0" y="0" /></mxGeometry></mxCell>

        <mxCell id="th" value="TIMING ILLUSTRATION — one transaction: START → address byte → ACK → STOP" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#17b8c9;strokeColor=#17b8c9;fontColor=#04222a;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="1747" width="700" height="40" as="geometry" /></mxCell>

        <mxCell id="p1" value="IDLE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="280" y="1827" width="180" height="40" as="geometry" /></mxCell>
        <mxCell id="p2" value="START (S)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="500" y="1827" width="180" height="40" as="geometry" /></mxCell>
        <mxCell id="p3" value="ADDRESS byte (A6..A0 + R/W)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="720" y="1827" width="240" height="50" as="geometry" /></mxCell>
        <mxCell id="p4" value="ACK" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1000" y="1827" width="180" height="40" as="geometry" /></mxCell>
        <mxCell id="p5" value="STOP (P)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1220" y="1827" width="180" height="40" as="geometry" /></mxCell>

        <mxCell id="lscl" value="SCL" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="1907" width="160" height="60" as="geometry" /></mxCell>
        <mxCell id="s1" value="high (idle)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="280" y="1907" width="180" height="60" as="geometry" /></mxCell>
        <mxCell id="s2" value="held high&#10;scl[i] &amp;&amp; scl[i-1]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="500" y="1907" width="180" height="60" as="geometry" /></mxCell>
        <mxCell id="s3" value="8 rising edges&#10;byte_start.get_or_insert(i); bits.push(sda[i])" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="1907" width="256" height="70" as="geometry" /></mxCell>
        <mxCell id="s4" value="9th rising edge&#10;bits[8] sampled" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1000" y="1907" width="180" height="60" as="geometry" /></mxCell>
        <mxCell id="s5" value="rises and stays high" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#4bc0e0;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1220" y="1907" width="180" height="60" as="geometry" /></mxCell>

        <mxCell id="lsda" value="SDA" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=13;" vertex="1" parent="1"><mxGeometry x="60" y="2007" width="160" height="70" as="geometry" /></mxCell>
        <mxCell id="d1" value="high (idle)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="280" y="2007" width="180" height="70" as="geometry" /></mxCell>
        <mxCell id="d2" value="1 → 0 while SCL high&#10;emits Kind::Start" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;" vertex="1" parent="1"><mxGeometry x="500" y="2007" width="180" height="70" as="geometry" /></mxCell>
        <mxCell id="d3" value="8 bits, MSB first&#10;value = (acc &lt;&lt; 1) | u8::from(b)&#10;emits Kind::Address" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="720" y="2007" width="252.8" height="70" as="geometry" /></mxCell>
        <mxCell id="d4" value="pulled low by receiver&#10;ok = ack = !bits[8]" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#141821;strokeColor=#2b3444;fontColor=#e6edf3;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1000" y="2007" width="180" height="70" as="geometry" /></mxCell>
        <mxCell id="d5" value="0 → 1 while SCL high&#10;emits Kind::Stop" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#1a1f2a;strokeColor=#f5c542;fontColor=#f5c542;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1220" y="2007" width="180" height="70" as="geometry" /></mxCell>

        <mxCell id="legend" value="Event::text() rendering:&#10;Kind::Start → &quot;S&quot;, Kind::RepeatedStart → &quot;Sr&quot;,&#10;Kind::Stop → &quot;P&quot;, value → &quot;{value:02X}&quot; with&#10;&quot;!&quot; appended when ok == false (NACK)" style="shape=note;whiteSpace=wrap;html=1;size=14;fillColor=#1a1f2a;strokeColor=#4bc0e0;fontColor=#adbac7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="1250" y="1360" width="352.9" height="170" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>